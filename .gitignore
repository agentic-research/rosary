/target

# Dolt database files (added by bd init)
.dolt/
*.db

# Local beads backups
backups/

# CRUMB - personal memory (not tracked)
.crumb/

# Dolt server runtime files
dolt-server.lock
dolt-server.log
dolt-server.pid
dolt-server.port
dolt/
.envrc
.env

# Agent workspace directories
.rsry-workspaces/

# Claude Code runtime artifacts (keep .claude/settings.json etc)
.claude/worktrees/
.claude/scheduled_tasks.lock
.claude/projects/

# Stale scripts from agent runs
.tmp-*
_push_fix.*
.fix-beads.py
_fix_stale_servers.py
_beads_clone/

# Experiments (local only)
experiments/

# Agent working logs (ephemeral review notes, not source)
_agent_logs/

# Local plan/scratch files (agent session plans, not tracked)
_*.md
