# === DENY ALL (whitelist approach) ===
# Everything at the root is ignored by default.
# Only explicitly listed items are tracked.
/*

# === RUST BUILD ===
!/Cargo.toml
!/Cargo.lock
!/build.rs
!/src
!/crates
!/tests

# === CONFIG ===
!/.cargo
!/Taskfile.yml
!/rosary.toml
!/rosary-self.toml
!/apko.yaml
!/melange.yaml
!/entitlements.plist

# === DOCS & DEFINITIONS ===
!/README.md
!/CLAUDE.md
!/AGENTS.md
!/LICENSE
!/docs
!/agents
!/skills
!/scripts

# === TOOLING ===
!/.gitignore
!/.mcp.json
!/.pre-commit-config.yaml
!/.github
!/.claude-plugin

# === BEADS (tracked config, not data) ===
!/.beads
/.beads/dolt/

# === BEAD STATE ===
!/.rsry-bead-id
!/.rsry-stream.jsonl
